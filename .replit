modules = ["nodejs-18", "web", "postgresql-16"]
[agent]
expertMode = true
integrations = ["javascript_supabase:1.0.0"]

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Development Server"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Frontend Server"

[[workflows.workflow]]
name = "Frontend Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev -- --port 5000 --hostname 0.0.0.0"
waitForPort = 5000

[[workflows.workflow]]
name = "Build for Production"
author = 47957149
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run build"

[[workflows.workflow]]
name = "Development Server"
author = 48032350
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev -- --port 3000 --hostname 0.0.0.0"

[[ports]]
localPort = 3000
externalPort = 3000

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["npm", "start"]
build = ["npm", "run", "build"]

[[deployment.envVarsSpec]]
name = "NEXT_PUBLIC_SUPABASE_URL"
description = "Supabase project URL"

[[deployment.envVarsSpec]]
name = "NEXT_PUBLIC_SUPABASE_ANON_KEY"
description = "Supabase anonymous key"
